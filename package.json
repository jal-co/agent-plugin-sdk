{
  "name": "agent-plugin-sdk-monorepo",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "test": "turbo test",
    "typecheck": "turbo typecheck",
    "build:sdk": "turbo build --filter=ap-sdk",
    "test:sdk": "turbo test --filter=ap-sdk",
    "prepare": "husky"
  },
  "packageManager": "pnpm@10.30.3",
  "devDependencies": {
    "husky": "^9.1.7",
    "turbo": "^2"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp"
    ]
  }
}
